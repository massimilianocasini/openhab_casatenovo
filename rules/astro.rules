var Timer myTimer_astro2 = null
var int iAutoOff = 0


rule "Apri tapparelle ad orario" // alle 7:00 dal lunedi al venerdi, solo se non è festivo e non è weekend, e se le tapparelle della camera da letto e dello studio sono ferme, e se la modalità "VoglioDormire" è disattivata
when
    Time cron "00 00 07 ? * MON,TUE,WED,THU,FRI *"
then
    if((Prodino0_optoIn0.state as Number).intValue == 0 && isBankHoliday == false && isWeekend == false && TapparellaLettoStatus.state == "stop" && TapparellaStudioStatus.state == "stop" && VoglioDormire.state == OFF)  {
        logInfo("Rule Astro", "Inizio procedura apertura serrande" )
        if(myTimer_astro2 !== null)                     // timer already scheduled, so leave rule
            return;
            iAutoOff = 0                              // initialize counter
            myTimer_astro2 = createTimer(now, [|
            iAutoOff ++
            switch(iAutoOff) {
                case  1 : { 
                        if(TapparellaLetto.state == 100) {
                            TapparellaLetto.sendCommand(90) }
                        if(TapparellaStudio.state == 100) {
                            TapparellaStudio.sendCommand(90) }
                        if(TapparellaSoggiorno.state == 100) {
                            TapparellaSoggiorno.sendCommand(90) }
                        if(TapparellaCameretta.state == 100) {
                            TapparellaCameretta.sendCommand(90) }
                        logInfo("Astro", "Procedura apertura serrande caso 1" )
                        }
                case  2 : {
                       if(TapparellaLetto.state == 90) { 
                            TapparellaLetto.sendCommand(70)}
                        if(TapparellaStudio.state == 90) {
                            TapparellaStudio.sendCommand(70) }
                        if(TapparellaSoggiorno.state == 90) {
                            TapparellaSoggiorno.sendCommand(70) }
                    //    if(TapparellaCameretta.state == 90) {
                    //        TapparellaCameretta.sendCommand(70) }
                        logInfo("Astro", "Procedura apertura serrande caso 2" )
                        }
                case  3 : {
                     //   if(TapparellaLetto.state == 70) { 
                     //       TapparellaLetto.sendCommand(40) }
                        if(TapparellaStudio.state == 70) {
                            TapparellaStudio.sendCommand(40) }
                        if(TapparellaSoggiorno.state == 70) {
                            TapparellaSoggiorno.sendCommand(40) }
                     //   if(TapparellaCameretta.state == 70) {
                     //       TapparellaCameretta.sendCommand(40) }
                        logInfo("Astro", "Procedura apertura serrande caso 3" )
                        }
         /*   case  4 : {
                        if(TapparellaLetto.state == 40) { 
                            TapparellaLetto.sendCommand(0) }
                        if(TapparellaStudio.state == 40) {
                            TapparellaStudio.sendCommand(0) }
                        if(TapparellaSoggiorno.state == 40) {
                            TapparellaSoggiorno.sendCommand(0) }
                    //    if(TapparellaCameretta.state == 40) {
                    //        TapparellaCameretta.sendCommand(0) }
                        logInfo("Astro", "Procedura apertura serrande caso 4" )
                        } */
                default : {
                myTimer_astro2 = null
                logInfo("Rule Astro", "Fine procedura apertura serrande" )
                return;
                }
        }
        myTimer_astro2.reschedule(now.plusMinutes(15))
        logInfo("Rule Astro", "Procedura apertura serrande timer reschedule" )
    ])
}
end

rule "Esegui azioni in base a SunElevation"
when
    Item SunElevation changed
then
        // --- Guardia NULL su SunElevation ---
    if(SunElevation.state == NULL) {
        logWarn("Rule Astro", "SunElevation è NULL, regola ignorata")
        return;
    }
        // --- Valori configurabili ---
    val int sogliaAlbaTramonto = 0
    val int sogliaChiusuraTapparelle    = -10 //Soglia per chiudere e resettare variabile tapparelle
    val int sogliaAperturaTapparelle    = 10 //Soglia per aprire e resettare variabile tapparelle
    val int sogliaAperturaTapparelle1   = 20 //Soglia usata per aprire tapparelle Studio e Soggiorno
    val int sogliaAperturaTenda         = 15 //Soglia usata per aprire tenda al mattino
    val int sogliaChiusuraTenda         = 10 //Soglia usata per resettare variabile chiusura tenda
    val int posTapparellaLettoNotte     = 92
    val int posTapparellaStudioNotte    = 92
    val int posTapparellaSoggiornoNotte = 97
    val int posTapparellaCamerettaNotte = 97
//    val int posTapparellaLettoGiorno     = 50
    val int posTapparellaStudioGiorno    = 50
    val int posTapparellaSoggiornoGiorno = 50
//    val int posTapparellaCamerettaGiorno = 50
    val float sunEl    = (SunElevation.state as Number).floatValue
    val int flagTapparelleAperte = if(vFlagTapparelleAperte.state == NULL) 0 else (vFlagTapparelleAperte.state as Number).intValue
    val int flagTapparelleChiuse = if(vFlagTapparelleChiuse.state == NULL) 0 else (vFlagTapparelleChiuse.state as Number).intValue
    val int flagTendaAperta = if(vFlagTendaAperta.state == NULL) 0 else (vFlagTendaAperta.state as Number).intValue
    val int flagTendaChiusa = if(vFlagTendaChiusa.state == NULL) 0 else (vFlagTendaChiusa.state as Number).intValue
     // Prodino0_optoIn0: 0 = DISINSERITO, 1 = INSERITO
    val int allarme = if(Prodino0_optoIn0.state == NULL) 0 else (Prodino0_optoIn0.state as Number).intValue

    // --- DIAGNOSTICA TEMPORANEA ---
    //gInfo("Rule Astro", "sunEl=" + sunEl + " flagChiusi=" + flagTapparelleChiuse + " allarme=" + allarme.state)

    // --- Inizializzazione flag se NULL (primo avvio prima di restoreOnStartup) ---
    if(vFlagTapparelleAperte.state == NULL) {
        logWarn("Rule Astro", "vFlagTapparelleAperte è NULL, inizializzo a 0")
        vFlagTapparelleAperte.postUpdate(0)
    }
    if(vFlagTapparelleChiuse.state == NULL) {
        logWarn("Rule Astro", "vFlagTapparellachiusi è NULL, inizializzo a 0")
        vFlagTapparelleChiuse.postUpdate(0)
    }
    if(vFlagTendaAperta.state == NULL) {
        logWarn("Rule Astro", "vFlagTendaAperta è NULL, inizializzo a 0")
        vFlagTendaAperta.postUpdate(0)
    }
    if(vFlagTendaChiusa.state == NULL) {
        logWarn("Rule Astro", "vFlagTendaChiusa è NULL, inizializzo a 0")
        vFlagTendaChiusa.postUpdate(0)
    }


    
    // --- Luce esterna ---
    if(sunEl <= sogliaAlbaTramonto && FGS222_004_SwitchBinary1.state == OFF) {
        logInfo("Rule Astro", "SunElevation <=  (" + sunEl + "°), accendo luce esterna")
        FGS222_004_SwitchBinary1.sendCommand(ON)
    }

    if(sunEl > sogliaAlbaTramonto && FGS222_004_SwitchBinary1.state == ON) {
        logInfo("Rule Astro", "SunElevation > (" + sunEl + "°), spengo luce esterna")
        FGS222_004_SwitchBinary1.sendCommand(OFF)
    }

    // --- Chiusura tapparelle a sera ---
    // Prodino0_optoIn0: 0 = DISINSERITO, 1 = INSERITO
    if(sunEl < sogliaChiusuraTapparelle && allarme == 0 && flagTapparelleChiuse == 0) {
        logInfo("Rule Astro", "SunElevation < (" + sunEl + "°), chiudo tapparelle")
        TapparellaLetto.sendCommand(posTapparellaLettoNotte)
        TapparellaStudio.sendCommand(posTapparellaStudioNotte)
        TapparellaSoggiorno.sendCommand(posTapparellaSoggiornoNotte)
        TapparellaCameretta.sendCommand(posTapparellaCamerettaNotte)
        vFlagTapparelleChiuse.postUpdate(1)
    }

    // --- Apertura tapparelle al mattino ---
    if(sunEl >= sogliaAperturaTapparelle1 && allarme == 0 && flagTapparelleAperte == 0 && isBankHoliday == false && isWeekend == false) {
        logInfo("Rule Astro", "SunElevation >= (" + sunEl + "°), apro tapparelle soggiorno e studio")
        if (TapparellaSoggiorno.state == posTapparellaSoggiornoNotte) {
            TapparellaSoggiorno.sendCommand(posTapparellaSoggiornoGiorno)
        }
        if (TapparellaStudio.state == posTapparellaStudioNotte) {
            TapparellaStudio.sendCommand(posTapparellaStudioGiorno)
        }
        vFlagTapparelleAperte.postUpdate(1)
    }
    // --- Apertura tenda al mattino (sole sopra soglia alta) ---
    if(sunEl >= sogliaAperturaTenda && flagTendaAperta == 0) {
        logInfo("Rule Astro", "SunElevation >= " + sogliaAperturaTenda + " (" + sunEl + "°), apro tenda")
        FGR223_014_BlindsControl.sendCommand(0)      // 
        vFlagTendaAperta.postUpdate(1)
        vFlagTendaChiusa.postUpdate(0)
    }

    // --- Chiusura tenda al tramonto (sole sotto soglia bassa) ---
    if(sunEl < sogliaChiusuraTenda && flagTendaChiusa == 0) {
        logInfo("Rule Astro", "SunElevation < " + sogliaChiusuraTenda + " (" + sunEl + "°), chiudo tenda")
        FGR223_014_BlindsControl.sendCommand(100)    // 
        vFlagTendaChiusa.postUpdate(1)
        vFlagTendaAperta.postUpdate(0)
    }

    // --- Reset flag apertura (sole sceso sotto soglia apertura) ---
    if(sunEl < sogliaAperturaTenda && flagTendaAperta == 1 && sunEl >= sogliaChiusuraTenda) {
        logInfo("Rule Astro", "SunElevation < " + sogliaAperturaTenda + " (" + sunEl + "°), reset flag apertura tenda")
        vFlagTendaAperta.postUpdate(0)
    }

    // --- Reset flag chiusura (sole risalito sopra soglia chiusura) ---
    if(sunEl >= sogliaChiusuraTenda && flagTendaChiusa == 1 && sunEl < sogliaAperturaTenda) {
        logInfo("Rule Astro", "SunElevation >= " + sogliaChiusuraTenda + " (" + sunEl + "°), reset flag chiusura tenda")
        vFlagTendaChiusa.postUpdate(0)
    }

    // --- Reset flag chiusura tapperelle---
    if(sunEl >= sogliaChiusuraTapparelle && flagTapparelleChiuse == 1) {
        logInfo("Rule Astro", "SunElevation >= (" + sunEl + "°), reset flag chiusura tapparelle")
        vFlagTapparelleChiuse.postUpdate(0)
    }

    // --- Reset flag apertura tapparelle---
    if(sunEl < sogliaAperturaTapparelle && flagTapparelleAperte == 1) {
        logInfo("Rule Astro", "SunElevation < (" + sunEl + "°), reset flag apertura tapparelle")
        vFlagTapparelleAperte.postUpdate(0)
    }
end

rule "Accensione Luce Garage"
when
    Item FGBS001_007_SensorBinary1 changed from OFF to ON
then
    if (SunElevation.state < 3) {
        if (FGS222_006_SwitchBinary2.state != ON) {
            FGS222_006_SwitchBinary2.sendCommand(ON)
            logInfo("Rule Astro", "Accesa luce garage perchè l'elevazione del sole è minore di 3")
        }
    }
end

