var Timer myTimer_astro2 = null
var int iAutoOff = 0
var int vTapparellastatus = 0
//var int vLuceEsterna = 0

rule "Apri tapparelle ad orario" // alle 7:00 dal lunedi al venerdi, solo se non è festivo e non è weekend, e se le tapparelle della camera da letto e dello studio sono ferme, e se la modalità "VoglioDormire" è disattivata
when
    Time cron "00 00 07 ? * MON,TUE,WED,THU,FRI *"
then
    if(Prodino0_optoIn0.state == "DISINSERITO" && isBankHoliday == false && isWeekend == false && TapparellaLettoStatus.state == "stop" && TapparellaStudioStatus.state == "stop" && VoglioDormire.state == OFF)  {
        logInfo("Rule Astro", "Inizio procedura apertura serrande" )
        if(myTimer_astro2 !== null)                     // timer already scheduled, so leave rule
            return;
            iAutoOff = 0                              // initialize counter
            myTimer_astro2 = createTimer(now, [|
            iAutoOff ++
            switch(iAutoOff) {
                case  1 : { 
                        if(TapparellaLetto.state == 100) {
                            TapparellaLetto.sendCommand(90) }
                        if(TapparellaStudio.state == 100) {
                            TapparellaStudio.sendCommand(90) }
                        if(TapparellaSoggiorno.state == 100) {
                            TapparellaSoggiorno.sendCommand(90) }
                        if(TapparellaCameretta.state == 100) {
                            TapparellaCameretta.sendCommand(90) }
                        logInfo("Astro", "Procedura apertura serrande caso 1" )
                        }
                case  2 : {
                       if(TapparellaLetto.state == 90) { 
                            TapparellaLetto.sendCommand(70)}
                        if(TapparellaStudio.state == 90) {
                            TapparellaStudio.sendCommand(70) }
                        if(TapparellaSoggiorno.state == 90) {
                            TapparellaSoggiorno.sendCommand(70) }
                    //    if(TapparellaCameretta.state == 90) {
                    //        TapparellaCameretta.sendCommand(70) }
                        logInfo("Astro", "Procedura apertura serrande caso 2" )
                        }
                case  3 : {
                     //   if(TapparellaLetto.state == 70) { 
                     //       TapparellaLetto.sendCommand(40) }
                        if(TapparellaStudio.state == 70) {
                            TapparellaStudio.sendCommand(40) }
                        if(TapparellaSoggiorno.state == 70) {
                            TapparellaSoggiorno.sendCommand(40) }
                     //   if(TapparellaCameretta.state == 70) {
                     //       TapparellaCameretta.sendCommand(40) }
                        logInfo("Astro", "Procedura apertura serrande caso 3" )
                        }
         /*   case  4 : {
                        if(TapparellaLetto.state == 40) { 
                            TapparellaLetto.sendCommand(0) }
                        if(TapparellaStudio.state == 40) {
                            TapparellaStudio.sendCommand(0) }
                        if(TapparellaSoggiorno.state == 40) {
                            TapparellaSoggiorno.sendCommand(0) }
                    //    if(TapparellaCameretta.state == 40) {
                    //        TapparellaCameretta.sendCommand(0) }
                        logInfo("Astro", "Procedura apertura serrande caso 4" )
                        } */
                default : {
                myTimer_astro2 = null
                logInfo("Rule Astro", "Fine procedura apertura serrande" )
                return;
                }
        }
        myTimer_astro2.reschedule(now.plusMinutes(15))
        logInfo("Rule Astro", "Procedura apertura serrande timer reschedule" )
    ])
}
end




rule "Esegui azioni in base a SunElevation"
when
Item SunElevation changed
then
    if(SunElevation.state < 0 && FGS222_004_SwitchBinary1.state == OFF) { // Accensione luce esterna se l'elevazione del sole è minore di 0 gradi
        logInfo("Rule Astro", "Condizione SunElevation < 0, accendo luce esterna")
        FGS222_004_SwitchBinary1.sendCommand(ON)
       }// vLuceEsterna = 1
      // else {
      //  logInfo("Rule Astro", "Luce portone non accesa perchè lo switch è " + FGS222_004_SwitchBinary1.state.toString() + " e l'elevazione è " + SunElevation.state.toString()) 
      // }
    if(SunElevation.state < -10 && SunElevation.state > -12 && vTapparellastatus == 0) { // Chiusura tapparelle se l'elevazione del sole è minore di -10 gradi
        logInfo("Rule Astro", "Condizione SunElevation > -3, chiusura tapparelle")
        TapparellaLetto.sendCommand(92) //Chiudi a 90% le tapparelle per far passare un po di luce
        TapparellaStudio.sendCommand(92)
        TapparellaSoggiorno.sendCommand(97)
        TapparellaCameretta.sendCommand(97)
        vTapparellastatus = 1
    }
    if(SunElevation.state < -12 && vTapparellastatus == 1) {
        logInfo("Rule Astro", "Condizione SunElevation < -11, reset variabile stato tapparelle")
        vTapparellastatus = 0
    }
    if(SunElevation.state > 0 && FGS222_004_SwitchBinary1.state == ON) { // Spegnimento luce esterna se l'elevazione del sole è maggiore di 0 gradi
        logInfo("Rule Astro", "Condizione SunElevation > 0, spengo luce esterna")
        FGS222_004_SwitchBinary1.sendCommand(OFF)
      //  vLuceEsterna = 0
    }
    if(SunElevation.state >= 10 && SunElevation.state <= 15 && Prodino0_optoIn0.state == "DISINSERITO" && vTapparellastatus == 0){ //apertura tapparelle soggiorno e studio se l'elevazione del sole è tra 10 e 15 gradi e il prodino è disinserito
        TapparellaSoggiorno.sendCommand(UP)
        TapparellaStudio.sendCommand(UP)
        vTapparellastatus = 1
    }
    if(SunElevation.state > 15 && vTapparellastatus == 1){ //reset variabile stato tapparelle
        vTapparellastatus = 0
    }
end

rule "Accensione Luce Garage"
when
    Item FGBS001_007_SensorBinary1 changed from OFF to ON
then
    if (SunElevation.state < 3) {
        if (FGS222_006_SwitchBinary2.state != ON) {
            FGS222_006_SwitchBinary2.sendCommand(ON)
            logInfo("Rule Astro", "Accesa luce garage perchè l'elevazione del sole è minore di 3")
        }
    }
end

rule "Chiusura tenda 60 minuti prima del tramonto"
when
    Channel 'astro:sun:local_offset60:set#event' triggered START
then
    logInfo("Rule Astro", "Tenda chiusa 60 minuti prima del tramonto")
    FGR223_014_BlindsControl.sendCommand(UP)
end
