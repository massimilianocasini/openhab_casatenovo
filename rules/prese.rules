//https://www.freeformatter.com/cron-expression-generator-quartz.html
//Seconds	Minutes	    Hours	Day Of Month	Month	Day Of Week	            Year
//  0	        30	      1	        ?	          *	    MON,TUE,WED,THU,FRI	    *
//var Timer myTimer = null
rule "Presa Garage 1 accendi alle 14"
when
    Time cron "0 0 14 ? * * *"
then
    // --- Presa Garage ---
    if (TimerPresa1Garage.state == ON) {
        Presa1GarageSwitch.sendCommand(ON)
        logInfo("Presa.rules", "Presa Garage 1 accesa alle 14")
    }

    // --- Presa Soggiorno (deodorante) ---
    // Prodino0_optoIn0 == 0 significa antifurto DISINSERITO
    if (Prodino0_optoIn0.state == "DISINSERITO"  && TimerPresa1Soggiorno.state == ON) {
        FGS221_016_SwitchBinary2.sendCommand(ON)
        logInfo("Presa.rules", "Presa soggiorno1 ON perchè Prodino0_optoIn0 è DISINSERITO")
    } else {
        logInfo("Presa.rules", "Presa soggiorno1 NON ON perchè Prodino0_optoIn0 è INSERITO o timer OFF")
    }
end

rule "Presa Garage 1 Spegni alle 20"
when
    Time cron "0 0 20 ? * * *"
then
    Presa1GarageSwitch.sendCommand(OFF)
    logInfo("Presa.rules", "Presa Garage 1 spenta alle 20")
end

rule "Presa Soggiorno 1 OFF"
when
    Time cron "0 0 23 ? * * *"
then
    FGS221_016_SwitchBinary2.sendCommand(OFF)
    logInfo("Presa.rules", "Presa soggiorno1 OFF alle 23")
end