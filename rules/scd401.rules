// ==============================================================================
// SCD40 Matter Device - OpenHAB 4.x/5.x Rules with Smart Debouncing
// ==============================================================================
// Copia questo file in: /etc/openhab/rules/scd40.rules
//
// FUNZIONALITÀ DEBOUNCING:
// - Attende 10 secondi dall'ultima modifica prima di inviare al device
// - Attende ulteriori 10 secondi prima di salvare in EEPROM
// - Evita di inviare ogni singolo step durante lo spostamento degli slider
// ==============================================================================

// Timer globali per debouncing — un solo timer attivo per volta
var Timer scd401DebounceTimer = null
var Timer scd401PersistTimer  = null

// ==============================================================================
// REGOLE DI CONVERSIONE CON DEBOUNCING
// ==============================================================================

rule "SCD401: Altitude Command (Meters -> Pending)"
when
    Item SCD401_Altitudine received command
then
    var int meters = (receivedCommand as Number).intValue

    // Limita il range a 0-5000 metri
    if (meters < 0) {
        meters = 0
        logWarn("SCD401", "Altitudine negativa ricevuta, impostata a 0m")
    } else if (meters > 5000) {
        meters = 5000
        logWarn("SCD401", "Altitudine troppo alta, impostata a 5000m")
    }

    // Salva il valore pending e aggiorna il timestamp per triggerare il debounce
    SCD401_AltitudePending.postUpdate(meters)
    SCD401_LastChangeMillis.postUpdate(now.toInstant.toEpochMilli)
end

rule "SCD401: Temperature Offset Command (Celsius -> Pending)"
when
    Item SCD401_TempOffset received command
then
    var float celsius = (receivedCommand as Number).floatValue

    // Limita il range a 0-10°C
    if (celsius < 0.0f) {
        celsius = 0.0f
        logWarn("SCD401", "Offset temperatura negativo, impostato a 0°C")
    } else if (celsius > 10.0f) {
        celsius = 10.0f
        logWarn("SCD401", "Offset temperatura troppo alto, impostato a 10°C")
    }

    // Salva il valore pending e aggiorna il timestamp per triggerare il debounce
    SCD401_TempOffsetPending.postUpdate(celsius)
    SCD401_LastChangeMillis.postUpdate(now.toInstant.toEpochMilli)
end

// ==============================================================================
// TIMER DEBOUNCING - Invia dopo 10 secondi di inattività
// ==============================================================================

rule "SCD401: Send pending values after 10s"
when
    Item SCD401_LastChangeMillis changed
then
    // Cancella il timer precedente — evita accumulo di timer in coda
    scd401DebounceTimer?.cancel()
    scd401DebounceTimer = createTimer(now.plusSeconds(10), [ |
        scd401DebounceTimer = null
        var boolean valuesSent = false

        // Invia altitudine se c'è un valore pending
        if (SCD401_AltitudePending.state !== NULL && SCD401_AltitudePending.state instanceof Number) {
            val int meters = (SCD401_AltitudePending.state as Number).intValue
            val float percentage = (meters * 100.0f / 5000.0f)
            SCD401_Altitudine_Raw.sendCommand(percentage)
            logInfo("SCD401", "Altitudine inviata: {}m", meters)
            valuesSent = true
        }

        // Invia offset temperatura se c'è un valore pending
        if (SCD401_TempOffsetPending.state !== NULL && SCD401_TempOffsetPending.state instanceof Number) {
            val float celsius = (SCD401_TempOffsetPending.state as Number).floatValue
            val float percentage = (celsius * 100.0f / 10.0f)
            SCD401_TempOffset_Raw.sendCommand(percentage)
            logInfo("SCD401", "Offset temperatura inviato: {}°C", celsius)
            valuesSent = true
        }

        // Aggiorna timestamp invio SOLO se almeno un valore è stato inviato
        if (valuesSent) {
            SCD401_SendTimestamp.postUpdate(now.toInstant.toEpochMilli)
        }
    ])
end

// ==============================================================================
// REGOLE DI UPDATE (Device -> UI)
// ==============================================================================

rule "SCD401: Altitude Update (Dimmer -> Meters)"
when
    Item SCD401_Altitudine_Raw changed
then
    if (SCD401_Altitudine_Raw.state == NULL) {
        logWarn("SCD401", "SCD401_Altitudine_Raw è NULL, ignorato")
        return;
    }
    val int percentage = (SCD401_Altitudine_Raw.state as Number).intValue
    val int meters     = (percentage * 5000 / 100)
    SCD401_Altitudine.postUpdate(meters)
end

rule "SCD401: Temperature Offset Update (Dimmer -> Celsius)"
when
    Item SCD401_TempOffset_Raw changed
then
    if (SCD401_TempOffset_Raw.state == NULL) {
        logWarn("SCD401", "SCD401_TempOffset_Raw è NULL, ignorato")
        return;
    }
    val int percentage  = (SCD401_TempOffset_Raw.state as Number).intValue
    val float celsius   = (percentage * 10.0f / 100.0f)
    SCD401_TempOffset.postUpdate(celsius)
end

// ==============================================================================
// REGOLE DI INIZIALIZZAZIONE
// ==============================================================================

rule "SCD401: Initialize on Startup"
when
    System started
then
    // Attendi 5 secondi per dare tempo al binding di popolare gli item
    createTimer(now.plusSeconds(5), [ |

        if (SCD401_Altitudine_Raw.state !== NULL && SCD401_Altitudine_Raw.state instanceof Number) {
            val int percentage = (SCD401_Altitudine_Raw.state as Number).intValue
            val int meters     = (percentage * 5000 / 100)
            SCD401_Altitudine.postUpdate(meters)
            logInfo("SCD401", "Altitudine inizializzata: {}m", meters)
        } else {
            logWarn("SCD401", "SCD401_Altitudine_Raw è NULL al boot, inizializzazione saltata")
        }

        if (SCD401_TempOffset_Raw.state !== NULL && SCD401_TempOffset_Raw.state instanceof Number) {
            val int percentage  = (SCD401_TempOffset_Raw.state as Number).intValue
            val float celsius   = (percentage * 10.0f / 100.0f)
            SCD401_TempOffset.postUpdate(celsius)
            logInfo("SCD401", "Offset temperatura inizializzato: {}°C", celsius)
        } else {
            logWarn("SCD401", "SCD401_TempOffset_Raw è NULL al boot, inizializzazione saltata")
        }
    ])
end

// ==============================================================================
// AUTO-PERSIST - Salva in EEPROM 10 secondi dopo l'invio al device
// ==============================================================================

rule "SCD401: Auto-persist 10s after sending to device"
when
    Item SCD401_SendTimestamp changed
then
    // Cancella il timer precedente — evita accumulo di timer in coda
    scd401PersistTimer?.cancel()
    scd401PersistTimer = createTimer(now.plusSeconds(10), [ |
        scd401PersistTimer = null
        logInfo("SCD401", "Auto-salvataggio valori continui in EEPROM")
        SCD401_Persist.sendCommand(ON)
        createTimer(now.plusSeconds(1), [ |
            SCD401_Persist.sendCommand(OFF)
        ])
    ])
end

// ==============================================================================
// AUTO-PERSIST - Salva immediatamente (con debounce 2s) per switch ASC e Low Power
// ==============================================================================

rule "SCD401: Auto-persist switch settings"
when
    Item SCD401_ASC      changed or
    Item SCD401_LowPower changed
then
    // Per gli switch il debounce è breve — 2 secondi sono sufficienti
    createTimer(now.plusSeconds(2), [ |
        logInfo("SCD401", "Auto-salvataggio switch in EEPROM")
        SCD401_Persist.sendCommand(ON)
        createTimer(now.plusSeconds(1), [ |
            SCD401_Persist.sendCommand(OFF)
        ])
    ])
end

// ==============================================================================
// MONITORAGGIO CO2
// ==============================================================================

rule "SCD401: Log CO2 warnings"
when
    Item SCD401_CO2 changed
then
    if (SCD401_CO2.state == NULL) {
        return;
    }
    val int co2 = (SCD401_CO2.state as Number).intValue

    if (co2 > 1000) {
        logWarn("SCD401", "CO2 elevato: {} ppm - Arieggia!", co2)
    } else if (co2 > 800) {
        logInfo("SCD401", "CO2 moderato: {} ppm", co2)
    }
end