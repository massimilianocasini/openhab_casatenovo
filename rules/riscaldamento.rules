var Timer awayTimer = null

rule "Manda in automatico (1) il cronotermostato alle 00:00"
when
    Time cron "0 00 00 ? * * *"
then
    // Rimanda in automatico solo se non è già disabilitato (stato 2)
    if(Riscaldamento_Modo.state != 2) {
        Riscaldamento_Modo.sendCommand(1)
    }
end

rule "Timer per disabilitazione temporanea riscaldamento"
when
    Item Riscaldamento_AwayTimer received update
then
    // Guard NULL
    if(Riscaldamento_AwayTimer.state == NULL) {
        logWarn("Timer Riscaldamento away", "Riscaldamento_AwayTimer è NULL, ignorato")
        return;
    }

    // Leggi i minuti di disabilitazione dall'item — locale, nessuno stato globale
    val int timeoutMinutes = (Riscaldamento_AwayTimer.state as Number).intValue
    logInfo("Timer Riscaldamento away", "Disabilitazione riscaldamento per " + timeoutMinutes + " minuti")
    Away_check.sendCommand(ON)

    if(awayTimer === null) {
        logInfo("Timer Riscaldamento away", "Timer start")
        awayTimer = createTimer(now.plusMinutes(timeoutMinutes), [|
            awayTimer = null
            Away_check.sendCommand(OFF)
            logInfo("Timer Riscaldamento away", "Timer concluso, riscaldamento riabilitato")
        ])
    }
    else {
        logInfo("Timer Riscaldamento away", "Timer reschedule a " + timeoutMinutes + " minuti")
        awayTimer.reschedule(now.plusMinutes(timeoutMinutes))
    }
end