//Cm3Panel 
String  Cm3panel    "CM3Panel"  <settings>  {channel="mqtt:topic:cm4home:cm3panel:system"}

// Tasmota Garage
Number ContatoreAcqua "Contatore acqua [%.0f]" (gTasmota, gInfluxdb) ["Measurement", "Water"] {channel="mqtt:topic:cm4home:flussometro:flusso"}
Switch ResetContatoreAcqua "Reset contatore acqua []" (gTasmota) ["Switch", "Water"] {channel="mqtt:topic:cm4home:flussometro:resetFlusso", expire="1s,command=OFF"}
Switch ElettrovalvolaAcqua "Elettrovalvola acqua []" (gValve) ["Switch", "Water"] {channel="mqtt:topic:cm4home:flussometro:elettrovalvola", stateDescription="" [options="OFF=APERTA, ON=CHIUSA"]}
String LWT "Stato Flussometro [%s]" (gTasmota) ["Status", "Water"] {channel="mqtt:topic:cm4home:flussometro:lwt", stateDescription="" [options="Online=ONLINE, Offline=OFFLINE"]}
